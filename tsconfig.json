{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node", "jest"],           // 👈 já está correto
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",                    // 👈 bom para organização
    "moduleResolution": "node",         // 👈 importante para imports automáticos
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src", "tests"]            // 👈 inclui arquivos .ts de src e testes
}
